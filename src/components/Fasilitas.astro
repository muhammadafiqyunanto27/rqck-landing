---
// src/components/Fasilitas.astro
---

<div id="fasilitas" class="-mt-12 pt-12"></div>
<section class="py-12 md:py-16 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center bg-white/40 backdrop-blur-xs p-4 md:p-6 rounded-3xl border border-[#063A24]/5 shadow-xs">
      
      <!-- KOLOM KIRI: TEKS & LIST ROW YANG BERWARNA & INTERAKTIF -->
      <div class="lg:col-span-7 space-y-6">
        <div>
          <span class="text-[#B59449] font-semibold text-xs tracking-wider uppercase block mb-1">Fasilitas & Keunggulan</span>
          <h2 class="text-[#063A24] font-bold text-2xl md:text-3xl leading-tight">Kenyamanan Belajar Terbaik</h2>
        </div>

        <div class="space-y-2">
          <!-- Poin 1 -->
          <div class="flex items-center gap-4 bg-[#FAF6EE]/40 backdrop-blur-xs p-2.5 rounded-xl border border-[#063A24]/10 shadow-3xs transition-all duration-300 hover:bg-[#063A24]/5 hover:border-[#B59449]/30 hover:translate-x-1 group cursor-pointer">
            <div class="w-8 h-8 rounded-lg bg-[#063A24] text-white flex items-center justify-center flex-shrink-0 shadow-xs transition-colors duration-300 group-hover:bg-[#B59449]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <h3 class="font-bold text-[#063A24] text-base transition-colors duration-300 group-hover:text-[#B59449]">Tempat Belajar Nyaman</h3>
              <p class="text-[#063A24]/80 text-xs sm:text-sm mt-0.5 leading-relaxed">Ruang kelas kondusif, tenang, dan bersih khusus akhwat.</p>
            </div>
          </div>

          <!-- Poin 2 -->
          <div class="flex items-center gap-4 bg-[#FAF6EE]/40 backdrop-blur-xs p-2.5 rounded-xl border border-[#063A24]/10 shadow-3xs transition-all duration-300 hover:bg-[#063A24]/5 hover:border-[#B59449]/30 hover:translate-x-1 group cursor-pointer">
            <div class="w-8 h-8 rounded-lg bg-[#063A24] text-white flex items-center justify-center flex-shrink-0 shadow-xs transition-colors duration-300 group-hover:bg-[#B59449]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <h3 class="font-bold text-[#063A24] text-base transition-colors duration-300 group-hover:text-[#B59449]">Bimbingan Intensif Ustadzah</h3>
              <p class="text-[#063A24]/80 text-xs sm:text-sm mt-0.5 leading-relaxed">Dibimbing langsung privat/semi-privat oleh Ustadzah kompeten.</p>
            </div>
          </div>

          <!-- Poin 3 -->
          <div class="flex items-center gap-4 bg-[#FAF6EE]/40 backdrop-blur-xs p-2.5 rounded-xl border border-[#063A24]/10 shadow-3xs transition-all duration-300 hover:bg-[#063A24]/5 hover:border-[#B59449]/30 hover:translate-x-1 group cursor-pointer">
            <div class="w-8 h-8 rounded-lg bg-[#063A24] text-white flex items-center justify-center flex-shrink-0 shadow-xs transition-colors duration-300 group-hover:bg-[#B59449]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <h3 class="font-bold text-[#063A24] text-base transition-colors duration-300 group-hover:text-[#B59449]">Kurikulum Terstruktur</h3>
              <p class="text-[#063A24]/80 text-xs sm:text-sm mt-0.5 leading-relaxed">Alur belajar jelas dan bertahap dari dasar hingga lancar.</p>
            </div>
          </div>

          <!-- Poin 4 -->
          <div class="flex items-center gap-4 bg-[#FAF6EE]/40 backdrop-blur-xs p-2.5 rounded-xl border border-[#063A24]/10 shadow-3xs transition-all duration-300 hover:bg-[#063A24]/5 hover:border-[#B59449]/30 hover:translate-x-1 group cursor-pointer">
            <div class="w-8 h-8 rounded-lg bg-[#063A24] text-white flex items-center justify-center flex-shrink-0 shadow-xs transition-colors duration-300 group-hover:bg-[#B59449]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <div>
              <h3 class="font-bold text-[#063A24] text-base transition-colors duration-300 group-hover:text-[#B59449]">Kuota Kelas Terbatas</h3>
              <p class="text-[#063A24]/80 text-xs sm:text-sm mt-0.5 leading-relaxed">Jumlah peserta dibatasi agar interaksi belajar jauh maksimal.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- KOLOM KANAN: KOTAK VISUAL DENGAN BINGKAI EMAS -->
      <div class="lg:col-span-5 relative w-full h-[280px] md:h-[340px] rounded-2xl overflow-hidden shadow-inner bg-[#063A24] p-3 flex items-center justify-center group">
        <div class="absolute inset-3 border border-[#B59449]/40 rounded-xl flex flex-col items-center justify-center p-4 text-center pointer-events-none z-10">
          <svg class="w-10 h-10 text-[#B59449] mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
          <h4 class="font-bold text-lg text-[#B59449] tracking-wide">Rumah Quran</h4>
          <p class="text-xs text-[#FAF6EE]/80 max-w-xs mt-1 leading-relaxed">Tempat belajar Al-Quran nyaman khusus akhwat.</p>
        </div>
        
        <img 
          src="/fasilitas.jpg" 
          alt="Fasilitas Belajar Rumah Quran" 
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 z-0"
          onerror="this.style.opacity='0'"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#042617]/50 to-transparent pointer-events-none z-10"></div>
      </div>

    </div>
  </div>
</section>
